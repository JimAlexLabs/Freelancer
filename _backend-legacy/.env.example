# ─── DATABASE ────────────────────────────────────────────────
# Option A: Supabase — use DATABASE_URL from Supabase Dashboard → Settings → Database
# DATABASE_URL=postgresql://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres

# Option B: Local or other Postgres
DB_HOST=localhost
DB_PORT=5432
DB_NAME=afrigig
DB_USER=afrigig_user
DB_PASSWORD=your_strong_password_here
DB_SSL=false          # set to true for remote (e.g. Supabase without DATABASE_URL)

# ─── JWT ─────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_64_byte_hex_secret
JWT_REFRESH_SECRET=replace_with_different_64_byte_hex_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── SERVER ──────────────────────────────────────────────────
PORT=4000
NODE_ENV=development         # development | production | test
FRONTEND_URL=http://localhost:3000
API_VERSION=v1

# ─── EMAIL (SMTP) ─────────────────────────────────────────────
# For dev use Mailtrap (https://mailtrap.io) — free sandbox
# For prod use Resend, SendGrid, or AWS SES
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
EMAIL_FROM=noreply@afrigig.com
EMAIL_FROM_NAME=AfriGig Platform

# ─── RATE LIMITING ───────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000   # 15 minutes
RATE_LIMIT_MAX=100            # requests per window per IP
AUTH_RATE_LIMIT_MAX=10        # stricter limit for auth endpoints

# ─── SECURITY ────────────────────────────────────────────────
BCRYPT_ROUNDS=12
EMAIL_VERIFY_EXPIRES=24h      # hours before verification link expires
PASSWORD_RESET_EXPIRES=1h     # hours before reset link expires

# ─── OPTIONAL: Redis for token blacklist ─────────────────────
# REDIS_URL=redis://localhost:6379
