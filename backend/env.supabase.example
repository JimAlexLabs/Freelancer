# Copy to backend/.env and replace [YOUR-PASSWORD] with your Supabase database password.
# Get password: Supabase Dashboard → Project Settings → Database → Database password (or reset).

# ─── Supabase (Direct connection) ─────────────────────────────
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.byxlhehjsvfqxpsqfxrx.supabase.co:5432/postgres

# If Direct fails (e.g. IPv4-only), use Session pooler URI from Dashboard instead.

# ─── JWT (generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))") ─
JWT_ACCESS_SECRET=replace_with_64_char_hex
JWT_REFRESH_SECRET=replace_with_different_64_char_hex
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# ─── Server ───────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:5173
API_VERSION=v1

# ─── Optional: email, rate limit, etc. (see .env.example) ───────
# SMTP_HOST=smtp.mailtrap.io
# SMTP_PORT=587
# ...
